# Airbyte Cloud API application credentials
# Create an application under Settings → Applications in the Airbyte Cloud UI
AIRBYTE_CLIENT_ID=your_airbyte_client_id
AIRBYTE_CLIENT_SECRET=your_airbyte_client_secret

# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
